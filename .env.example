# ──────────────────────────────────────────────────────────────
# Root .env — consumed by docker-compose.yml
# ──────────────────────────────────────────────────────────────

NODE_ENV=development

# MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=eta_saas
MYSQL_USER=eta_user
MYSQL_PASSWORD=eta_password
MYSQL_ROOT_PASSWORD=root_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Backend / API
API_PORT=4000
API_PREFIX=/api
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=change-me-too-very-long-random
JWT_REFRESH_EXPIRES=7d
BCRYPT_ROUNDS=10
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# ETA (Egyptian Tax Authority)
ETA_BASE_URL=https://api.preprod.invoicing.eta.gov.eg
ETA_ID_BASE_URL=https://id.preprod.eta.gov.eg
ETA_CLIENT_ID=
ETA_CLIENT_SECRET=
ETA_ENVIRONMENT=preprod

# WhatsApp Business Cloud API (Meta)
# If both values are empty, sends run in mock mode (no real delivery)
WHATSAPP_PROVIDER=meta
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Paymob payment gateway (mock mode unless all 3 are set)
PAYMOB_BASE_URL=https://accept.paymob.com/api
PAYMOB_CHECKOUT_URL=https://accept.paymob.com/unifiedcheckout/
PAYMOB_API_KEY=
PAYMOB_PUBLIC_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_HMAC_SECRET=

# Public-facing URLs (used in payment links & webhooks)
PUBLIC_APP_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:4000/api

# OpenAI (AI layer — Phase 3 scaffold)
OPENAI_API_KEY=

# Optional launch promo applied to every paid plan price (0 = off, max 90).
# Use this for early-access discounts without editing plans.ts.
LAUNCH_DISCOUNT_PERCENT=0

# Frontend
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_APP_NAME=ETA SaaS

# Nginx
NGINX_PORT=80
