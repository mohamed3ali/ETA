NODE_ENV=development

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=eta_saas
MYSQL_USER=eta_user
MYSQL_PASSWORD=eta_password
# true only on a first-boot empty DB to let TypeORM create tables;
# keep false afterwards and use migrations / scripts/fix-schema-drift.
DB_SYNCHRONIZE=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# API
API_PORT=4000
API_PREFIX=/api
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=debug

# Auth
JWT_SECRET=please-change-me
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=please-change-me-too
JWT_REFRESH_EXPIRES=7d
BCRYPT_ROUNDS=10

# ETA
ETA_BASE_URL=https://api.preprod.invoicing.eta.gov.eg
ETA_ID_BASE_URL=https://id.preprod.eta.gov.eg
ETA_CLIENT_ID=
ETA_CLIENT_SECRET=
ETA_ENVIRONMENT=preprod

# WhatsApp (Phase 2)
WHATSAPP_PROVIDER=meta
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# AI (Phase 3)
OPENAI_API_KEY=
